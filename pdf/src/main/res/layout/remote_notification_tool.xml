<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- 第一个按钮及标题 -->

    <RelativeLayout
        android:id="@+id/btn_container_1"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:gravity="center"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_pdf"
            android:layout_marginTop="5dp"
            android:src="@mipmap/noti_tool_image_pdf"
            android:layout_centerHorizontal="true"
            android:layout_width="38dp"
            android:layout_height="38dp"/>
<!--        <TextView-->
<!--            android:layout_centerHorizontal="true"-->
<!--            android:layout_below="@id/iv_pdf"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="2dp"-->
<!--            android:gravity="center"-->
<!--            android:text="@string/notification_btn_doc"-->
<!--            android:textColor="#333333"-->
<!--            android:textSize="10sp"/>-->

        <TextView
            android:id="@+id/tv_pdf_message_number"
            android:text="0"
            android:textSize="7sp"
            android:textColor="@color/white"
            android:maxLength="2"
            android:gravity="center"
            android:background="@drawable/circle_red"
            android:layout_alignTop="@id/iv_pdf"
            android:layout_alignEnd="@id/iv_pdf"
            android:layout_alignRight="@id/iv_pdf"
            android:layout_marginTop="-6.5dp"
            android:layout_marginEnd="-4.5dp"
            android:layout_marginRight="-7.5dp"
            android:layout_width="15dp"
            android:layout_height="15dp"/>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/btn_container_2"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:gravity="center"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <ImageView
            android:layout_marginTop="5dp"
            android:src="@mipmap/noti_tool_scan_pdf"
            android:layout_width="38dp"
            android:layout_height="38dp"/>
<!--        <TextView-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="2dp"-->
<!--            android:gravity="center"-->
<!--            android:text="@string/notification_btn_scan"-->
<!--            android:textColor="#333333"-->
<!--            android:textSize="10sp"/>-->

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/btn_container_3"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:gravity="center"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_clean"
            android:layout_marginTop="5dp"
            android:src="@mipmap/noti_tool_file_clean"
            android:layout_centerHorizontal="true"
            android:layout_width="38dp"
            android:layout_height="38dp"/>
<!--        <TextView-->
<!--            android:layout_centerHorizontal="true"-->
<!--            android:layout_below="@id/iv_clean"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="2dp"-->
<!--            android:gravity="center"-->
<!--            android:text="@string/notification_btn_clean"-->
<!--            android:textColor="#333333"-->
<!--            android:textSize="10sp"/>-->

        <TextView
            android:id="@+id/tv_clean_message_number"
            android:textSize="7sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/circle_red"
            android:layout_alignTop="@id/iv_clean"
            android:layout_alignEnd="@id/iv_clean"
            android:layout_alignRight="@id/iv_clean"
            android:layout_marginTop="-6.5dp"
            android:layout_marginEnd="-4.5dp"
            android:layout_marginRight="-7.5dp"
            android:layout_width="15dp"
            android:layout_height="15dp"/>

    </RelativeLayout>


</LinearLayout>