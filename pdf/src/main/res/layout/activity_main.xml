<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".ui.main.MainActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/page_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    <View
        android:background="#e5e5e5"
        android:layout_width="match_parent"
        android:layout_height="0.5dp" />

    <com.wwdablu.soumya.lottiebottomnav.LottieBottomNav
        android:id="@+id/lottie_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@android:color/white"
        app:menu_selected_height="28dp"
        app:menu_selected_width="28dp"
        app:menu_unselected_height="28dp"
        app:menu_unselected_width="28dp"
        app:menu_text_show_on_unselected="true" />

    <FrameLayout
        android:id="@+id/ad_view_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 导航栏占位 View，高度会在代码中动态设置为导航栏高度 -->
    <View
        android:id="@+id/nav_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white" />
</LinearLayout>