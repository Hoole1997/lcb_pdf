<?xml version="1.0" encoding="utf-8"?>
<com.noober.background.view.BLConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingTop="20dp"
    android:paddingStart="15dp"
    android:paddingEnd="15dp"
    android:paddingBottom="35dp"
    app:bl_solid_color="@color/white"
    app:bl_corners_topRadius="15dp">

    <TextView
        android:id="@+id/tv_title"
        android:text="@string/action_rename"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <com.noober.background.view.BLEditText
        android:id="@+id/et_content"
        tools:text="jfaodijf aiopsdjfaiopsdjfajsdofiajsdfiopaj"
        android:paddingStart="10dp"
        android:paddingEnd="50dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        app:bl_solid_color="#dfe0e4"
        app:bl_corners_radius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="15dp"
        android:layout_width="match_parent"
        android:minHeight="50dp"
        android:layout_height="wrap_content"/>

    <ImageView
        android:id="@+id/iv_clear"
        android:src="@drawable/cancel_24px"
        app:layout_constraintTop_toTopOf="@id/et_content"
        app:layout_constraintBottom_toBottomOf="@id/et_content"
        app:layout_constraintEnd_toEndOf="@id/et_content"
        android:padding="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/et_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:text="@string/action_cancel"
            android:textColor="@color/black"
            android:backgroundTint="#ebebeb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <Space
            android:layout_width="50dp"
            android:layout_height="wrap_content"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:text="@string/action_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</com.noober.background.view.BLConstraintLayout>