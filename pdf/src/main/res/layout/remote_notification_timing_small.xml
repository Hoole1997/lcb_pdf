<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:maxHeight="64dp">

    <ImageView
        android:id="@+id/iv_notification_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerVertical="true"
        android:src="@mipmap/notification_icon_7" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/iv_notification_icon"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="10dp"
        android:layout_toLeftOf="@id/rl_open"
        android:layout_toRightOf="@id/iv_notification_icon"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="New image for creating PDF" />

    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/iv_notification_icon"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="5dp"
        android:layout_toLeftOf="@id/rl_open"
        android:layout_toRightOf="@id/iv_notification_icon"
        android:ellipsize="end"
        android:singleLine="true"
        android:textSize="14sp"
        tools:text="Free up space by removing screenshots you no longer need." />

    <RelativeLayout
        android:id="@+id/rl_open"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10dp">

        <ProgressBar
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_alignStart="@id/btn_open"
            android:layout_alignTop="@id/btn_open"
            android:layout_alignEnd="@id/btn_open"
            android:layout_alignBottom="@id/btn_open"
            android:indeterminate="true"
            android:indeterminateDrawable="@drawable/noti_timing_notify_btn_long"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <TextView
            android:id="@+id/btn_open"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="open"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </RelativeLayout>

</RelativeLayout>