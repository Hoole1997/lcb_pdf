<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".ui.main.MainActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/page_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:background="@android:color/white"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/nav_file"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_main_bottom_nav_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="5dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_file_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/main_tab_file"
                android:src="@drawable/ic_main_navigation_file_24px" />

            <TextView
                android:id="@+id/nav_file_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:text="@string/main_tab_file"
                android:textColor="@color/main_bottom_nav_selected"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_recent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_main_bottom_nav_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="5dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_recent_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/main_tab_recent"
                android:src="@drawable/ic_main_navigation_recent_24px" />

            <TextView
                android:id="@+id/nav_recent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:text="@string/main_tab_recent"
                android:textColor="@color/main_bottom_nav_unselected_text"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_favorite"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_main_bottom_nav_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="5dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_favorite_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/main_tab_favorite"
                android:src="@drawable/ic_main_navigation_favorite_24px" />

            <TextView
                android:id="@+id/nav_favorite_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:text="@string/main_tab_favorite"
                android:textColor="@color/main_bottom_nav_unselected_text"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tools"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_main_bottom_nav_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="5dp"
            android:paddingBottom="4dp">

            <ImageView
                android:id="@+id/nav_tools_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/main_tab_tools"
                android:src="@drawable/ic_main_navigation_tools_24px" />

            <TextView
                android:id="@+id/nav_tools_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:text="@string/main_tab_tools"
                android:textColor="@color/main_bottom_nav_unselected_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/ad_view_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 导航栏占位 View，高度会在代码中动态设置为导航栏高度 -->
    <View
        android:id="@+id/nav_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/white" />
</LinearLayout>
