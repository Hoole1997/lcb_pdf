<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_modern"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- 标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_option_card"
                android:gravity="center"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_save"
                    android:tint="@color/dialog_save_icon_tint" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dialogTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_save_dialog_title"
                    android:textColor="@color/dialog_title_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:singleLine="true"
                    android:text="@string/pdf_save_dialog_subtitle"
                    android:textColor="@color/dialog_subtitle_text"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 保存选项标题 -->
        <TextView
            android:id="@+id/saveOptionsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/pdf_save_options_title"
            android:textColor="@color/dialog_option_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 保存选项卡片 -->
        <RadioGroup
            android:id="@+id/saveOptionGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical">

            <!-- 保存为新文件选项 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_option_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:id="@+id/saveAsNewContainer">

                <RadioButton
                    android:id="@+id/saveAsNewRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:button="@drawable/radio_button_selector"
                    android:checked="true"
                    android:clickable="false"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_save_as_new"
                        android:textColor="@color/dialog_option_title"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/pdf_save_as_new_desc"
                        android:textColor="#6B7280"
                        android:singleLine="true"
                        android:textSize="12sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_left"
                    android:rotation="180"
                    android:tint="#9CA3AF" />

            </LinearLayout>

            <!-- 覆盖当前文件选项 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:id="@+id/overwriteContainer">

                <RadioButton
                    android:id="@+id/overwriteRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:button="@drawable/radio_button_selector"
                    android:clickable="false"
                    android:focusable="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_save_overwrite"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/pdf_save_overwrite_desc"
                        android:textColor="#6B7280"
                        android:singleLine="true"
                        android:textSize="12sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_left"
                    android:rotation="180"
                    android:tint="#9CA3AF" />

            </LinearLayout>

        </RadioGroup>

        <!-- 文件名输入区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/pdf_save_file_name_label"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/fileNameLayout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/fileNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="@string/pdf_save_file_name_hint"
                    android:textColorHint="#9CA3AF"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:textColor="#1F2937"
                    android:textSize="16sp" />

            </FrameLayout>

            <TextView
                android:id="@+id/fileNameHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/pdf_save_file_name_helper"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/fileNameError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:singleLine="true"
                android:background="@drawable/bg_button_modern_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/action_cancel"
                android:textColor="#6B7280"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/confirmButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_modern_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/choose_file_delete_confirm_ok"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>