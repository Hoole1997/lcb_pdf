<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Frame 1 -->
    <item android:duration="100">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#4A90E2" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <item android:left="-60dp" android:right="30dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00FFFFFF"
                        android:centerColor="#60FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Frame 2 -->
    <item android:duration="100">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#4A90E2" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <item android:left="-30dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00FFFFFF"
                        android:centerColor="#60FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Frame 3 -->
    <item android:duration="100">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#4A90E2" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <item android:left="0dp" android:right="-30dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00FFFFFF"
                        android:centerColor="#60FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Frame 4 -->
    <item android:duration="100">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#4A90E2" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <item android:left="30dp" android:right="-60dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="0"
                        android:startColor="#00FFFFFF"
                        android:centerColor="#60FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- 暂停 -->
    <item android:duration="1200">
        <shape android:shape="rectangle">
            <solid android:color="#4A90E2" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    
</animation-list>