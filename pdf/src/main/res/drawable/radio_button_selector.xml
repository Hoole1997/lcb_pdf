<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中且按下状态 -->
    <item android:state_checked="true" android:state_pressed="true" android:drawable="@drawable/radio_button_checked" />
    
    <!-- 选中状态 -->
    <item android:state_checked="true" android:drawable="@drawable/radio_button_checked" />
    
    <!-- 未选中且按下状态 -->
    <item android:state_checked="false" android:state_pressed="true" android:drawable="@drawable/radio_button_unchecked" />
    
    <!-- 未选中状态 -->
    <item android:state_checked="false" android:drawable="@drawable/radio_button_unchecked" />
    
    <!-- 默认状态 -->
    <item android:drawable="@drawable/radio_button_unchecked" />
</selector>