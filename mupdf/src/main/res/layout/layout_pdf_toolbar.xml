<?xml version="1.0" encoding="utf-8"?>
<!-- 简化版PDF工具栏 - 仅缩放功能 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pdfToolbarContainer"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@color/card_background"
    android:elevation="1dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <!-- 缩小按钮 -->
    <ImageButton
        android:id="@+id/zoomOutBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/tool_button_background"
        android:src="@drawable/ic_zoom_out"
        android:scaleType="centerInside"
        app:tint="@color/text_secondary"
        android:contentDescription="@string/zoom_out"
        android:layout_marginEnd="8dp" />

    <!-- 缩放比例 -->
    <TextView
        android:id="@+id/zoomLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/zoom_level"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:minWidth="40dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="8dp" />

    <!-- 放大按钮 -->
    <ImageButton
        android:id="@+id/zoomInBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/tool_button_background"
        android:src="@drawable/ic_zoom_in"
        android:scaleType="centerInside"
        app:tint="@color/text_secondary"
        android:contentDescription="@string/zoom_in"
        android:layout_marginEnd="8dp" />

    <!-- 适应宽度按钮 -->
    <ImageButton
        android:id="@+id/fitWidthBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/tool_button_background"
        android:src="@drawable/ic_fit_width"
        android:scaleType="centerInside"
        app:tint="@color/text_secondary"
        android:contentDescription="@string/fit_width" />

</LinearLayout>
